# Required: Anthropic API key for Claude SDK sessions
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Task broker port (default: 8090)
# BROKER_PORT=8090

# Optional: Mock MCP server port (default: 8091)
# MCP_PORT=8091
